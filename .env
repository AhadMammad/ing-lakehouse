# ─────────────────────────────────────────────
#  ing-lakehouse — global environment variables
# ─────────────────────────────────────────────

# Docker Compose project name (prefixes all containers/networks/volumes)
COMPOSE_PROJECT_NAME=ing-lakehouse

# ── RustFS ───────────────────────────────────
RUSTFS_IMAGE=rustfs/rustfs:latest-glibc
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin123
RUSTFS_LOG_LEVEL=debug

# Ports exposed on the host
RUSTFS_S3_PORT=9000       # S3 API (via nginx load balancer)
RUSTFS_CONSOLE_PORT=9011  # Web console (via nginx) — 9001 is taken by VSCode on macOS

# ── RustFS SSL / DNS ──────────────────────────────────────────
RUSTFS_DOMAIN=rustfs.lakehouse.local

# ── Spark ─────────────────────────────────────────────────────
SPARK_IMAGE=apache/spark:3.5.3
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8080
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_IMAGE=apache/kafka:3.7.0
# Generate once: docker run --rm confluentinc/cp-kafka:7.6.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BROKER_PORT=9092    # single-node broker / broker-1 in distributed
KAFKA_BROKER2_PORT=9094   # broker-2 (distributed only)
KAFKA_BROKER3_PORT=9095   # broker-3 (distributed only)

# ── Nessie (Iceberg REST catalog) ─────────────────────────────
NESSIE_IMAGE=ghcr.io/projectnessie/nessie:0.99.0
NESSIE_PORT=19120

# ── Jupyter ───────────────────────────────────────────────────
JUPYTER_PORT=8888
JUPYTER_TOKEN=lakehouse

# ── Iceberg ───────────────────────────────────────────────────
ICEBERG_WAREHOUSE_BUCKET=iceberg-warehouse
