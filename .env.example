# ─────────────────────────────────────────────
#  ing-lakehouse — environment variables template
#  Copy to .env and fill in secrets:  cp .env.example .env
# ─────────────────────────────────────────────

# Docker Compose project name (prefixes all containers/networks/volumes)
COMPOSE_PROJECT_NAME=ing-lakehouse

# ── RustFS ───────────────────────────────────
RUSTFS_IMAGE=rustfs/rustfs:latest-glibc
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
RUSTFS_LOG_LEVEL=debug

# Ports exposed on the host
RUSTFS_S3_PORT=9000       # S3 API (via nginx load balancer)
RUSTFS_CONSOLE_PORT=9011  # Web console (via nginx) — 9001 is taken by VSCode on macOS

# ── RustFS SSL / DNS ──────────────────────────────────────────
RUSTFS_DOMAIN=rustfs.lakehouse.local

# ── Spark ─────────────────────────────────────────────────────
SPARK_IMAGE=apache/spark:3.5.3
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8080
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_IMAGE=apache/kafka:3.7.0
# Generate once: docker run --rm confluentinc/cp-kafka:7.6.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=changeme-generate-with-kafka-storage-random-uuid
KAFKA_BROKER_PORT=9092    # single-node broker / broker-1 in distributed
KAFKA_BROKER2_PORT=9094   # broker-2 (distributed only)
KAFKA_BROKER3_PORT=9095   # broker-3 (distributed only)

# ── Nessie (Iceberg REST catalog) ─────────────────────────────
NESSIE_IMAGE=ghcr.io/projectnessie/nessie:0.99.0
NESSIE_PORT=19120

# ── Jupyter ───────────────────────────────────────────────────
JUPYTER_PORT=8888
JUPYTER_TOKEN=changeme

# ── Iceberg ───────────────────────────────────────────────────
ICEBERG_WAREHOUSE_BUCKET=iceberg-warehouse

# ── Trino ─────────────────────────────────────────────────────
TRINO_IMAGE=trinodb/trino:469
TRINO_PORT=8081         # 8081 avoids conflict with Spark UI on 8080

# ── CloudBeaver (web SQL IDE for Trino) ───────────────────────
CLOUDBEAVER_IMAGE=dbeaver/cloudbeaver:latest
HUE_PORT=8000           # 8000 avoids conflict with Jupyter on 8888

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_IMAGE=apache/airflow:3.2.1
AIRFLOW_PORT=8082              # 8082 avoids Spark UI (8080), Trino (8081)
AIRFLOW_FERNET_KEY=            # Leave blank for dev (Airflow auto-generates); set in .env.<instance> for stable restarts
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme

# ── Payments Source PostgreSQL ────────────────────────────────────────────────
POSTGRES_SOURCE_PORT=5433
POSTGRES_SOURCE_DB=payments
POSTGRES_SOURCE_USER=payments
POSTGRES_SOURCE_PASSWORD=changeme

# ── Rideon Source database ────────────────────────────────────
# Second database in the same postgres-source container (created by
# init/02_rideon.sql on a fresh volume). Shares the user/password above.
RIDEON_SOURCE_DB=rideon

# ── dbt (Trino transforms) ────────────────────────────────────
# dbt builds the rideon silver/gold layers over the in-network Trino
# `nessie` catalog — no extra secrets needed. Image is built per-instance
# as ${COMPOSE_PROJECT_NAME}-dbt:latest via `make build-dbt`.

# ── Network ───────────────────────────────────────────────────
# Explicit subnet prevents Docker from exhausting its default pool when
# multiple instances run on the same host.  init-instance assigns each
# instance its own /24 from 10.100.x.0/24 automatically.
NETWORK_SUBNET=10.100.0.0/24
